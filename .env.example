# PostHog "Project token" (the phc_… value). Required.
# In the PostHog UI it's shown under "Project token & ID". This is the value the
# SDK ingests events with. (Personal keys, phx_…, are not this — don't use them.)
POSTHOG_PROJECT_TOKEN=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostHog host. Defaults to PostHog Cloud US (https://us.i.posthog.com).
# EU: https://eu.i.posthog.com  |  local dev stack: http://localhost:8010
# POSTHOG_HOST=https://us.i.posthog.com

# Port for the Streamable HTTP server (defaults to 3000).
# PORT=3000
