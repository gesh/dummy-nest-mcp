{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2022",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "types": ["node"],
    "skipLibCheck": true,
    "strict": false,
    "outDir": "dist"
  },
  "include": ["src/**/*.ts"]
}
